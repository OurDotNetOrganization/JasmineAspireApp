<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:strings="clr-namespace:MauiApp2.Resources.Strings"
             x:Class="MauiApp2.MainPage"
             Title="{x:Static strings:AppResources.PageTitle}">

    <Grid RowDefinitions="Auto,*" Padding="16,12">
        <Label x:Name="StatusLabel"
               Text="{x:Static strings:AppResources.LoadingProfile}"
               FontSize="12"
               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="14">
                <Label x:Name="NameLabel"
                       Text="Jasmine Dwidar"
                       FontSize="28"
                       FontAttributes="Bold" />

                <Label x:Name="KickerLabel"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />

                <Label x:Name="HeroLabel"
                       FontSize="15"
                       LineBreakMode="WordWrap" />

                <Label x:Name="ValueTitleLabel"
                       FontSize="18"
                       FontAttributes="Bold" />

                <Label x:Name="ValueIntroLabel"
                       FontSize="14"
                       LineBreakMode="WordWrap" />

                <CollectionView x:Name="OutcomesCollection"
                                SelectionMode="None"
                                HeightRequest="120">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Label Text="{Binding .}" FontSize="13" Margin="0,4,0,0" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="{x:Static strings:AppResources.ContactInquiry}" FontSize="18" FontAttributes="Bold" />

                <Entry x:Name="NameEntry" Placeholder="{x:Static strings:AppResources.YourName}" />
                <Entry x:Name="EmailEntry" Placeholder="{x:Static strings:AppResources.YourEmail}" Keyboard="Email" />
                <Entry x:Name="OrganizationEntry" Placeholder="{x:Static strings:AppResources.OrganizationOptional}" />
                <Editor x:Name="MessageEditor"
                        Placeholder="{x:Static strings:AppResources.MessagePlaceholder}"
                        AutoSize="TextChanges"
                        MinimumHeightRequest="110" />

                <Button x:Name="SubmitButton"
                        Text="{x:Static strings:AppResources.SubmitInquiry}"
                        Clicked="OnSubmitClicked" />

                <Label x:Name="SubmitResultLabel"
                       FontSize="12"
                       LineBreakMode="WordWrap" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
