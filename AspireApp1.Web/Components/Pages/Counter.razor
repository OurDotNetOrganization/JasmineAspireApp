@page "/counter"
@rendermode InteractiveServer

<PageTitle>@AppResources.CounterPageTitle</PageTitle>

<h1>@AppResources.CounterPageTitle</h1>

<p role="status">@AppResources.FormatCurrentCount(currentCount)</p>

<button class="btn btn-primary" @onclick="IncrementCount">@AppResources.ClickMe</button>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}
